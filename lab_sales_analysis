SELECT * FROM lab_sales;

SELECT 
SUM(Units_Sold * Price) AS Total_Revenue
FROM lab_sales;

SELECT Product_Name,
SUM(Units_Sold) AS Total_Units
FROM lab_sales
GROUP BY Product_Name
ORDER BY Total_Units DESC;

SELECT Department,
SUM(Units_Sold * Price) AS Revenue
FROM lab_sales
GROUP BY Department;

SELECT Product_Name, Stock_Left
FROM lab_sales
WHERE Stock_Left < 10;

SELECT Category,
SUM(Units_Sold * Price) AS Revenue
FROM lab_sales
GROUP BY Category
ORDER BY Revenue DESC;
