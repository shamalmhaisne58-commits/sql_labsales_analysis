CREATE DATABASE Lab_Analytics;

USE Lab_Analytics;

CREATE TABLE lab_sales (
    Product_ID INT,
    Product_Name VARCHAR(50),
    Category VARCHAR(50),
    Department VARCHAR(50),
    Units_Sold INT,
    Price INT,
    Stock_Left INT,
    Month VARCHAR(20)
);

